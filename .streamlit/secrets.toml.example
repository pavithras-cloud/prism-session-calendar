# Copy this file to  .streamlit/secrets.toml  and fill in real values.
# Until you do, the app runs fine and falls back to .ics export.

[gcp_service_account]
# Paste the fields from your service-account JSON key here:
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_KEY_WITH_\\n_LINE_BREAKS\n-----END PRIVATE KEY-----\n"
client_email = "prism-bot@your-project-id.iam.gserviceaccount.com"
client_id = "..."
token_uri = "https://oauth2.googleapis.com/token"

[sheets]
# Shared multi-user data. Create a Google Sheet, share it with the
# service-account client_email above as Editor, and paste its ID here
# (the long string in the sheet URL between /d/ and /edit).
# Leave this section out to keep using the local file instead.
sheet_id = "1AbCdEf_your_google_sheet_id_here"

[app]
calendar_id = "c_xxxxxxxxxxxx@group.calendar.google.com"   # the shared "Prism Academy" calendar
impersonate = "pavithra.s@homelane.com"                    # requires domain-wide delegation; blank to disable
admin_email = "pavithra.s@homelane.com"
